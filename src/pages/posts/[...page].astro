---
import type { Page, GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/Base";
import PostPreview from "@/components/blog/PostPreview";
import Pagination from "@/components/Paginator";
import { publishedPosts, sortMDByDate } from "@/utils";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("post");
  const allPostsByDate = sortMDByDate(publishedPosts(allPosts));
  return paginate(allPostsByDate, { pageSize: 50 });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<"post">>;
}

const { page } = Astro.props;

const meta = {
  title: "Archive",
  description: "Essays and notes by Sunil Pai on software, systems, tools, and the changing craft of programming.",
};

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      url: page.url.prev,
      text: `← Previous Posts`,
    },
  }),
  ...(page.url.next && {
    nextUrl: {
      url: page.url.next,
      text: `Next Posts →`,
    },
  }),
};
---

<PageLayout meta={meta}>
  <p class="eyebrow">Everything, newest first</p>
  <h1 class="display-title mb-8 mt-3">Writing archive</h1>
  <div>
    <section aria-label="Blog post list">
      <ul class="space-y-8 text-start">
        {
          page.data.map((p) => (
            <li class="flex flex-col flex-wrap gap-2 sm:flex-row [&_q]:basis-full">
              <PostPreview post={p} as="h2" withDesc />
            </li>
          ))
        }
      </ul>
      <Pagination {...paginationProps} />
    </section>
  </div>
</PageLayout>
