---
import type { Page, GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/Base";
import PostPreview from "@/components/blog/PostPreview";
import Pagination from "@/components/Paginator";
import { publishedPosts, sortMDByDate } from "@/utils";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("post");
  const allPostsByDate = sortMDByDate(publishedPosts(allPosts));
  return paginate(allPostsByDate, { pageSize: 50 });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<"post">>;
}

const { page } = Astro.props;

const meta = {
  title: "Archive",
  description: "Essays and notes by Sunil Pai on software, systems, tools, and the changing craft of programming.",
};

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      url: page.url.prev,
      text: `← Previous Posts`,
    },
  }),
  ...(page.url.next && {
    nextUrl: {
      url: page.url.next,
      text: `Next Posts →`,
    },
  }),
};
---

<PageLayout meta={meta}>
  <header class="mb-14">
    <p class="eyebrow">Writing</p>
    <h1 class="display-title mt-3">The archive.</h1>
    <p class="mt-6 max-w-[40rem] text-lg leading-8 text-muted">
      Essays and notes about software, systems, developer tools, and the changing craft of
      programming.
    </p>
  </header>

  <section aria-labelledby="all-writing">
    <div class="mb-6 flex items-baseline justify-between gap-4 border-b border-dotted border-divider pb-3">
      <h2 id="all-writing" class="section-title">All writing</h2>
      <p class="eyebrow shrink-0">{page.total} pieces · newest first</p>
    </div>
    <ul class="divide-y divide-dotted divide-divider text-start">
      {
        page.data.map((p) => (
          <li class="py-5 first:pt-0">
            <div class="flex flex-col gap-x-4 sm:flex-row sm:items-baseline">
              <PostPreview post={p} as="h3" />
            </div>
            <p class="mt-2 max-w-[38rem] text-sm leading-6 text-muted sm:ms-[136px]">
              {p.data.description}
            </p>
          </li>
        ))
      }
    </ul>
    <div class="mt-8 border-t border-dotted border-divider pt-4">
      <Pagination {...paginationProps} />
    </div>
  </section>
</PageLayout>
