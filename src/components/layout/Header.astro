---
import ThemeToggle from "../ThemeToggle.astro";
import Search from "../Search.astro";
import { MENU_LINKS } from "@/data/constants";

import { Image } from "astro:assets";
import logoPng from "../../assets/logo.png";

const url = new URL(Astro.request.url);
---

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.getElementById("main-header") as HTMLElement;
    const toggleMenuButton = document.getElementById("toggle-navigation-menu") as HTMLButtonElement;
    const navigationMenu = document.getElementById("navigation-menu") as HTMLElement;

    function setMenuOpen(open: boolean) {
      header.classList.toggle("menu-open", open);
      toggleMenuButton.setAttribute("aria-expanded", open.toString());
      toggleMenuButton.setAttribute("aria-label", open ? "Close main menu" : "Open main menu");
    }

    toggleMenuButton.addEventListener("click", () => {
      setMenuOpen(toggleMenuButton.getAttribute("aria-expanded") !== "true");
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggleMenuButton.getAttribute("aria-expanded") === "true") {
        setMenuOpen(false);
        toggleMenuButton.focus();
      }
    });

    document.addEventListener("click", (event) => {
      if (!header.contains(event.target as Node)) setMenuOpen(false);
    });

    navigationMenu.addEventListener("click", () => setMenuOpen(false));
  });
</script>

<header id="main-header" class="group relative mb-20 flex items-center sm:ps-[4.5rem]">
  <div class="flex sm:flex-col">
    <a
      href="/"
      class="inline-flex items-center sm:relative sm:inline-block"
      aria-current={url.pathname === "/" ? "page" : false}
    >
      <Image
        src={logoPng}
        alt=""
        loading="eager"
        class="me-3 h-10 w-10 sm:absolute sm:start-[-4.5rem] sm:me-0 sm:h-16 sm:w-16"
      />

      <span class="site-name text-xl sm:text-2xl">Sunil Pai</span>
    </a>
    <nav
      id="navigation-menu"
      class="absolute -inset-x-4 top-14 hidden flex-col items-end gap-y-4 rounded-md bg-[--theme-menu-bg] py-4 text-sm text-accent shadow backdrop-blur group-[.menu-open]:z-50 group-[.menu-open]:flex sm:static sm:z-auto sm:-ms-4 sm:mt-1 sm:flex sm:flex-row sm:items-center sm:divide-x sm:divide-dotted sm:divide-gray-500 sm:rounded-none sm:bg-transparent sm:py-0 sm:shadow-none sm:backdrop-blur-none"
      aria-label="Main menu"
    >
      {
        MENU_LINKS.map((link) => (
          <a
            href={link.path}
            class="px-4 py-4 sm:py-0 sm:hover:underline"
            aria-current={
              url.pathname === link.path ||
              (link.path === "/posts/" && url.pathname.startsWith("/posts/"))
                ? "page"
                : false
            }
            rel="prefetch"
          >
            {link.title}
          </a>
        ))
      }
    </nav>
  </div>
  <Search />
  <ThemeToggle />
  <button
    id="toggle-navigation-menu"
    class="group relative ms-2 h-11 w-11 sm:invisible sm:hidden"
    type="button"
    aria-label="Open main menu"
    aria-expanded="false"
    aria-controls="navigation-menu"
  >
    <svg
      id="line-svg"
      class="absolute start-1/2 top-1/2 h-full w-full -translate-x-1/2 -translate-y-1/2 transition-all group-aria-expanded:scale-0 group-aria-expanded:opacity-0"
      aria-hidden="true"
      focusable="false"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
    </svg>
    <svg
      id="cross-svg"
      class="absolute start-1/2 top-1/2 h-full w-full -translate-x-1/2 -translate-y-1/2 scale-0 text-accent opacity-0 transition-all group-aria-expanded:scale-100 group-aria-expanded:opacity-100"
      aria-hidden="true"
      focusable="false"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</header>
